[sub_resource type="Shader" id=5]
code = "shader_type canvas_item;

uniform float u_time : hint_range(-1., 1.) = 0.;
uniform float shrink_size : hint_range(0., 1.) = 1.;

 float my_glow_alpha(vec2 my_uv,  float my_t) {
	 float my_alpha = smoothstep(-.05, 0., my_uv.x) * smoothstep(1.05, 1., my_uv.x) * smoothstep(-.1, 0., my_uv.y) * smoothstep(1.1, 1., my_uv.y);
	
	return my_alpha;
}

void fragment() {
	vec2 uv = UV;
	uv.y += 1.5 * u_time;
	uv -= (1. - shrink_size) * .5 * u_time;
	
	uv /= (1. - u_time) * 1. + u_time * shrink_size;
	
	vec3 tex = texture(TEXTURE, uv).rgb;
	
	if (uv.y < 1.0/18.0) {
		tex = vec3(0);
	}
	if (uv.y > 17.0/18.0) {
		tex = vec3(0);
	}
	
	COLOR.rgb = (1. - u_time) * tex * step(0., uv.x) * step(0., uv.y) * step(uv.x, 1.) * step(uv.y, 1.) + clamp((u_time * vec3(1., 1., 0.)), 0., 1.);
	COLOR.a *= my_glow_alpha(uv, u_time);
	
	
}"

