[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;
uniform float brightness :hint_range(0,1) = 0.;
uniform float size :hint_range(0.5,5) = 1.;

void fragment() {
	vec2 uv = UV;
	uv -= .5;
	uv /= size;
	uv += .5;
	
	uv *= step(0., uv.x) * step(uv.x, 1.) * step(0., uv.y) * step(uv.y, 1.);
	
	float f = 1. - 
		smoothstep(0., .25, UV.x) * smoothstep(1., .75, UV.x) *
		smoothstep(0., .25, UV.y) * smoothstep(1., .75, UV.y);
	f *= .95 + sin(TIME * 45.0) * .05;
	f *= brightness;
	
	vec4 s = texture(TEXTURE,uv);
	s.a *= smoothstep(.5, 1., size) * smoothstep(5., 1., size);
	
	COLOR = s;
	COLOR.rg += vec2(f * .75);
}"

