[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

uniform float time : hint_range(0, 1) = 0.0;

void fragment()
{	
	COLOR = vec4(0.0,0.0,0.0,1.0);
	
	vec2 uv = UV;
	vec2 center = vec2(0.5, 0.5);
	
	COLOR.a = min((0.2 + distance(uv, center)) * time*5.0, 0.9);
}
"

[sub_resource type="ShaderMaterial" id=2]
shader = SubResource( 1 )
shader_parameter/time = 0.0

[sub_resource type="GDScript" id=3]
script/source = "extends Node2D

var now_select_index = 0

func _ready():
	now_select_index = 0
	update_cursor_pos()



func _input(event):
	if !visible: return
	
	if(Input.is_action_just_pressed(\"ui_down\")):
		move_cursor(2)
	if(Input.is_action_just_pressed(\"ui_up\")):
		move_cursor(8)
	if(Input.is_action_just_pressed(\"ui_cancel\") || Input.is_action_just_pressed(\"ui_joy_cancel\")):
		play_cancel_se()
		close()
	if(Input.is_action_just_pressed(\"ui_accept\")):
		if now_select_index == 0:
			play_click_se()
			close()
		else:
			play_click_se()
			request_close_game()

func move_cursor(d):
	match d:
		2:
			now_select_index = 1
		8:
			now_select_index = 0
	
	update_cursor_pos()
	play_walking_se()

func update_cursor_pos():
	var pos = [$no, $yes][now_select_index].position - Vector2(60,0)
	$cursor.position = pos

var walking_foot_cycle = false
func play_walking_se():
	var r = randi()%6+2
	var db = -10
	var pan
	if walking_foot_cycle:
		pan = -0.3
	else:
		pan = 0.3
	walking_foot_cycle = !walking_foot_cycle
	
	Sound.play_se(\"res://Sounds/se/footstep_\"+str(r)+\".wav\", db, pan)


func play_typing_se():
	Sound.play_typing_se()

func play_click_se():
	Sound.play_se(\"res://Sounds/se/typerwriter_feedpaper_2.wav\")

func play_adjust_se():
	Sound.play_se(\"res://Sounds/se/typerwriter_feedpaper_1.wav\")

func play_cancel_se():
	Sound.play_se(\"res://Sounds/se/system/SE_S_25_cancel.wav\")


func open():
	now_select_index = 0
	update_cursor_pos()
	await get_tree().process_frame
	visible = true

signal closed
func close():
	now_select_index = 0
	visible = false
	emit_signal(\"closed\")

signal close_game
func request_close_game():
	Global.return_to_title_screen()
	await get_tree().create_timer(1.0).timeout
	
	close()
	
	emit_signal(\"close_game\")
	pass
"

